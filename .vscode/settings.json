{
	"cSpell.diagnosticLevel": "Hint",
	"cSpell.enabled": false,
	"editor.formatOnPaste": true,
	"editor.formatOnSave": true,
	"editor.formatOnSaveMode": "file",
	"explorer.compactFolders": false,
	"files.eol": "\n",
	"files.insertFinalNewline": true,
	"files.trimTrailingWhitespace": true,
	"files.trimFinalNewlines": true,
	"git.autoStash": true, // return last stash: git stash apply
	"git.rebaseWhenSync": true, // cancel: git rebase --abort
	"[jsonc]": {
		"editor.defaultFormatter": "vscode.json-language-features",
		"editor.quickSuggestions": {
			"strings": true
		},
		"editor.suggest.insertMode": "replace",
		"editor.wordWrapColumn": 120
	},
	"[markdown]": {
		"editor.formatOnSave": true,
		"editor.wordWrap": "bounded",
		"editor.wordWrapColumn": 120
	},
	"[lua][luau]": {
		"editor.defaultFormatter": "JohnnyMorganz.stylua"
	},
	"[powershell]": {
		"debug.saveBeforeStart": "nonUntitledEditorsInActiveGroup",
		"editor.defaultFormatter": "ms-vscode.powershell",
		"editor.formatOnSave": true,
		"editor.formatOnType": true,
		"editor.codeActionsOnSave": {
			"source.fixAll": "explicit"
		},
		"editor.semanticHighlighting.enabled": false,
		"editor.wordSeparators": "`~!@#$%^&*()=+[{]}\\|;:'\",.<>/?"
	},
	"[shellscript]": {
		"files.eol": "\n",
		"editor.formatOnSave": true,
		"editor.wordWrap": "on"
	},
	"[yaml]": {
		"editor.defaultFormatter": "redhat.vscode-yaml",
		"editor.formatOnSave": true,
		"editor.tabSize": 2,
		"editor.wordWrap": "bounded",
		"editor.wordWrapColumn": 120
	},
	"files.exclude": {
		"Packages": true,
		"ServerPackages": true
	},
	"search.exclude": {
		"**/node_modules": true,
		"**/bower_components": true,
		"**/*.code-search": true,
		"**/.history": true
	},
	"material-icon-theme.files.associations": {
		"*.story.luau": "Storybook",
		"*.luau": "Lua"
	},
	"material-icon-theme.folders.associations": {
		"story": "Storybook",
		"component": "Components",
		"reflex": "Cart",
		"ui": "Interface",
		"tags": "Log",
		"siteComponents": "Public"
	},
	"luau-lsp.completion.imports.requireStyle": "alwaysAbsolute",
	"luau-lsp.completion.imports.separateGroupsWithLine": true,
	"luau-lsp.completion.imports.enabled": true,
	"luau-lsp.sourcemap.rojoProjectFile": "default.project.json",
	"robloxLsp.completion.alwaysShowMethods": true,
	"robloxLsp.completion.callParenthesess": true,
	"robloxLsp.completion.endAutocompletion": true,
	"robloxLsp.hint.returnType": true,
	"robloxLsp.hint.setType": true,
	"robloxLsp.hint.paramName": true,
	"robloxLsp.hint.enable": true,
	"robloxLsp.typeChecking.mode": "Non Strict",
	"powershell.codeFormatting.addWhitespaceAroundPipe": true,
	"powershell.codeFormatting.autoCorrectAliases": true,
	"powershell.codeFormatting.newLineAfterCloseBrace": true,
	"powershell.codeFormatting.newLineAfterOpenBrace": true,
	"powershell.codeFormatting.openBraceOnSameLine": true,
	"powershell.codeFormatting.pipelineIndentationStyle": "NoIndentation",
	"powershell.codeFormatting.useCorrectCasing": true,
	"powershell.codeFormatting.whitespaceAfterSeparator": true,
	"powershell.codeFormatting.whitespaceAroundOperator": true,
	"powershell.codeFormatting.whitespaceBeforeOpenBrace": true,
	"powershell.codeFormatting.whitespaceBeforeOpenParen": true,
	"stylua.targetReleaseVersion": "latest",
}
